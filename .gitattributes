# SafeSight-MLOps — Git Line Ending Rules
# Overrides core.autocrlf for all contributors and CI runners.
# Rule: files that run on Linux stay LF. Files that only run on Windows stay CRLF.

# ── Default: normalize everything to LF in the repo, checkout as-is ──────────
* text=auto eol=lf

# ── Force LF — files that execute on Linux (CI, Docker, GitHub Actions) ───────
*.sh             text eol=lf
*.bash           text eol=lf
Dockerfile*      text eol=lf
*.dockerignore   text eol=lf
.dockerignore    text eol=lf
*.yml            text eol=lf
*.yaml           text eol=lf
*.env            text eol=lf
*.env.*          text eol=lf
*.conf           text eol=lf
*.nginx          text eol=lf
requirements.txt text eol=lf
Makefile         text eol=lf

# ── Force CRLF — Windows-only files ──────────────────────────────────────────
*.bat            text eol=crlf
*.cmd            text eol=crlf
*.ps1            text eol=crlf

# ── Text files — normalize to LF ─────────────────────────────────────────────
*.js             text eol=lf
*.ts             text eol=lf
*.tsx            text eol=lf
*.jsx            text eol=lf
*.json           text eol=lf
*.md             text eol=lf
*.txt            text eol=lf
*.css            text eol=lf
*.html           text eol=lf
*.sql            text eol=lf
*.py             text eol=lf

# ── Binary files — never touch line endings ───────────────────────────────────
*.png            binary
*.jpg            binary
*.jpeg           binary
*.gif            binary
*.ico            binary
*.svg            binary
*.webp           binary
*.mp4            binary
*.pt             binary
*.weights        binary
*.woff           binary
*.woff2          binary
*.ttf            binary
*.eot            binary
