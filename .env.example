# ─────────────────────────────────────────────────────────────────────
# Tasuke'26 — Cyber Sentinel Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────────

# ── WEB DASHBOARD (Node.js) ──────────────────────────────────────────
PORT=4000

# MongoDB Connection String (Update if using a remote DB)
MONGO_URI=mongodb://mongodb:27017/safesight

# Authentication Secret
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-secure-random-secret

# Email Notifications (Nodemailer)
# Leave blank to disable email alerts.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
ALERT_EMAIL_TO=security-team@yourorg.com


# ── AI ENGINE (Python) ────────────────────────────────────────────────
# The AI engine uses these to authenticate and talk to the dashboard

# Find your API Key in the Dashboard UI (Nodes section)
SAFESIGHT_API_KEY=082235d3-fa46-4d62-a22d-a62763502eda

# URL of the dashboard alert API
DASHBOARD_URL=http://localhost:4000/api/alert

# Camera Configuration
CAMERA_INDEX=0
CONFIDENCE_THRESHOLD=0.6
FRAME_RATE_LIMIT=15
