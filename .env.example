# ─────────────────────────────────────────────────────────────────────
# SafeSight Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/safesight

# ── Authentication ─────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-secure-random-secret

# ── Email Notifications (Nodemailer) ──────────────────────────────────
# Leave blank to disable email alerts.
# For Gmail: use an App Password (Google Account → Security → App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
ALERT_EMAIL_TO=security-team@yourorg.com
